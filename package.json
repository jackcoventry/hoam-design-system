{
  "name": "hoam-design-system",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "npx vitest --project=storybook",
    "tokens-old": "style-dictionary build --config style-dictionary.json",
    "icon:tokens": "node src/scripts/generate-icons.mjs",
    "icons": "npm run icon:tokens && svg-sprite --config svg.json --log=info \"src/icons/*.svg\"",
    "tokens": "node src/scripts/register-style-dictionary.mjs",
    "dev": "storybook dev -p 6006",
    "build": "npm run tokens && rollup -c",
    "prepare": "npm run build",
    "build-storybook": "storybook build"
  },
