{
  "name": "hoam-design-system",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "npx vitest --project=storybook",
    "tokens": "style-dictionary build --config style-dictionary.json",
    "icon:tokens": "node scripts/generate-icons.mjs",
    "icons": "npm run icon:tokens && svg-sprite --config svg.json --log=info \"src/icons/*.svg\"",
    "dev": "storybook dev -p 6006",
    "build": "npm run tokens && rollup -c",
    "prepare": "npm run build",
    "build-storybook": "storybook build"
  },
  "author": "Jack Coventry",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.3",
    "@rollup/plugin-url": "^8.0.2",
    "@storybook/addon-vitest": "^9.0.13",
    "@storybook/react-vite": "^9.0.13",
    "@types/node": "^24.0.4",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "playwright": "^1.53.1",
    "prop-types": "^15.8.1",
    "rollup": "^4.44.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^9.0.13",
    "style-dictionary": "^5.0.0",
    "svg-sprite": "^2.0.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
