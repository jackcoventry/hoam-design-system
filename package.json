{
  "name": "hoam-design-system",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prettier": "prettier . --check",
    "tokens-old": "style-dictionary build --config style-dictionary.json",
    "icon:tokens": "tsx src/scripts/generate-icons.ts",
    "icons": "npm run icon:tokens && svg-sprite --config svg.json --log=info \"src/icons/*.svg\"",
    "tokens": "tsx src/scripts/register-style-dictionary.ts",
    "dev": "storybook dev -p 6006",
    "build": "npm run tokens && vite build",
    "build-storybook": "storybook build",
    "verify": "npm run build && npm run prettier && npm run lint && npm run typecheck && npm run test:run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro,json,md,css}": [
      "prettier . --check"
    ],
    "*.{js,jsx,ts,tsx,astro}": [
      "eslint ."
    ]
  },
  "author": "Jack Coventry",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "clsx": "^2.1.1",
    "deepmerge": "^4.3.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "10.2.19",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "playwright": "^1.53.1",
    "prettier": "3.6.2",
    "prop-types": "^15.8.1",
    "sass": "^1.93.2",
    "storybook": "^10.2.19",
    "style-dictionary": "^5.0.1",
    "svg-sprite": "^2.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.65.0",
    "swiper": "^12.0.3",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  }
}
