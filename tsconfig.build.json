{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": false
  },
  "include": ["src"],
  "exclude": [
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "src/scripts/**",
    ".storybook/**",
    "config/**",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
