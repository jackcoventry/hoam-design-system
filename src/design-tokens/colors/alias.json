{
  "color": {
    "$type": "color",
    "accent": {
      "$extensions": {
        "$group": "accent"
      },
      "default": {
        "$value": "{palette.purple.500}"
      },
      "soft": {
        "$value": "{palette.purple.300}"
      },
      "strong": {
        "$value": "{palette.purple.700}"
      }
    },
    "text": {
      "$extensions": {
        "$group": "text"
      },
      "default": {
        "$value": "{palette.neutral.100}"
      },
      "soft": {
        "$value": "{palette.neutral.800}"
      },
      "inverse": {
        "$value": "{palette.neutral.900}"
      }
    },
    "link": {
      "$extensions": {
        "$group": "link"
      },
      "default": {
        "$value": "{color.accent.default}"
      },
      "hover": {
        "$value": "{color.accent.strong}"
      }
    },
    "surface": {
      "$extensions": {
        "$group": "surface"
      },
      "default": {
        "$value": "{palette.neutral.100}"
      },
      "soft": {
        "$value": "{palette.neutral.800}"
      },
      "inverse": {
        "$value": "{palette.neutral.900}"
      },
      "accent": {
        "$value": "{color.accent.soft}"
      },
      "accent-strong": {
        "$value": "{color.accent.strong}"
      },
      "accent-soft": {
        "$value": "{color.accent.soft}"
      }
    },
    "border": {
      "default": {
        "$value": "{palette.neutral.700}"
      },
      "soft": {
        "$value": "{palette.neutral.800}"
      },
      "strong": {
        "$value": "{palette.neutral.500}"
      },
      "accent": {
        "$value": "{color.accent.default}"
      }
    },
    "feedback": {
      "error": {
        "$value": "{palette.semantic.error}"
      },
      "warning": {
        "$value": "{palette.semantic.warning}"
      },
      "success": {
        "$value": "{palette.semantic.success}"
      },
      "info": {
        "$value": "{palette.semantic.info}"
      }
    }
  }
}
