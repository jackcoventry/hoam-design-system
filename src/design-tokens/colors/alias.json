{
  "color": {
    "$type": "color",
    "accent": {
      "$extensions": {
        "$group": "accent"
      },
      "soft": {
        "$value": "{palette.primary.300}",
        "$description": "A softer version of the accent color"
      },
      "default": {
        "$value": "{palette.primary.500}",
        "$description": "The default accent colour for this theme"
      },
      "strong": {
        "$value": "{palette.primary.700}",
        "$description": "A stronger version of the accent color"
      }
    },
    "text": {
      "$extensions": {
        "$group": "text"
      },
      "default": {
        "$value": "{palette.neutral.100}"
      },
      "soft": {
        "$value": "{palette.neutral.700}"
      },
      "inverse": {
        "$value": "{palette.neutral.900}"
      }
    },
    "link": {
      "$extensions": {
        "$group": "link"
      },
      "default": {
        "$value": "{color.accent.default}"
      },
      "hover": {
        "$value": "{color.accent.soft}"
      }
    },
    "surface": {
      "$extensions": {
        "$group": "surface"
      },
      "default": {
        "$value": "{palette.neutral.100}"
      },
      "muted": {
        "$value": "{palette.neutral.500}"
      },
      "soft": {
        "$value": "{palette.neutral.800}"
      },
      "inverse": {
        "$value": "{palette.neutral.900}"
      },
      "accent": {
        "$value": "{color.accent.default}"
      },
      "accent-soft": {
        "$value": "{color.accent.soft}"
      },
      "alpha": {
        "$value": "{palette.neutral-alpha.200}"
      },
      "alpha-soft": {
        "$value": "{palette.neutral-alpha.100}"
      },
      "alpha-strong": {
        "$value": "{palette.neutral-alpha.500}"
      },
      "alpha-inverse": {
        "$value": "{palette.neutral-alpha.600}"
      }
    },
    "border": {
      "$extensions": {
        "$group": "border"
      },
      "soft": {
        "$value": "{palette.neutral.800}"
      },
      "default": {
        "$value": "{palette.neutral.700}"
      },
      "strong": {
        "$value": "{palette.neutral.500}"
      },
      "accent": {
        "$value": "{color.accent.default}"
      }
    },
    "feedback": {
      "$extensions": {
        "$group": "feedback"
      },
      "error": {
        "$value": "{palette.semantic.error}"
      },
      "warning": {
        "$value": "{palette.semantic.warning}"
      },
      "success": {
        "$value": "{palette.semantic.success}"
      },
      "info": {
        "$value": "{palette.semantic.info}"
      }
    }
  }
}
