{
  "shadow": {
    "small": {
      "$type": "shadow",
      "$value": {
        "color": "{color.surface.alpha}",
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "3px",
        "spread": "0"
      }
    },
    "medium": {
      "$type": "shadow",
      "$value": {
        "color": "{color.surface.alpha}",
        "offsetX": "0",
        "offsetY": "10px",
        "blur": "24px",
        "spread": "-8px"
      }
    },
    "large": {
      "$type": "shadow",
      "$value": {
        "color": "{color.surface.alpha}",
        "offsetX": "0",
        "offsetY": "24px",
        "blur": "60px",
        "spread": "-18px"
      }
    }
  }
}
