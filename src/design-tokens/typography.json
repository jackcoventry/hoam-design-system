{
  "typography": {
    "family": {
      "1": {
        "$type": "fontFamily",
        "$value": [
          "Boldonse",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      },
      "2": {
        "$type": "fontFamily",
        "$value": [
          "DM Serif Text",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      },
      "3": {
        "$type": "fontFamily",
        "$value": [
          "Roboto",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      }
    },
    "size": {
      "base": {
        "$type": "dimension",
        "$value": "18px"
      },
      "1": {
        "$type": "dimension",
        "$value": "14px"
      },
      "2": {
        "$type": "dimension",
        "$value": "{typography.size.base}"
      },
      "3": {
        "$type": "dimension",
        "$value": "clamp(1rem, min(20vmin, 7vw), 2rem)"
      },
      "4": {
        "$type": "dimension",
        "$value": "clamp(1rem, min(20vmin, 7vw), 3rem)"
      },
      "5": {
        "$type": "dimension",
        "$value": "clamp(1rem, min(20vmin, 7vw), 6rem)"
      }
    },
    "line-height": {
      "1": {
        "$value": 1.5
      },
      "2": {
        "$value": 1.75
      },
      "3": {
        "$value": 1.25
      },
      "4": {
        "$value": 1.1
      },
      "5": {
        "$value": 2
      }
    },
    "letter-spacing": {
      "1": {
        "$type": "dimension",
        "$value": "0"
      },
      "2": {
        "$type": "dimension",
        "$value": "1px"
      }
    },
    "weight": {
      "1": {
        "$type": "fontWeight",
        "$value": 300
      },
      "2": {
        "$type": "fontWeight",
        "$value": 400
      },
      "3": {
        "$type": "fontWeight",
        "$value": 700
      }
    },
    "title": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.1}",
          "fontWeight": "{typography.weight.2}",
          "fontSize": "{typography.size.5}",
          "lineHeight": "{typography.line-height.2}"
        },
        "$extensions": {
          "$targetElement": "h1",
          "$name": "Title"
        }
      },
      "2": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.4}",
          "lineHeight": "{typography.line-height.4}"
        },
        "$extensions": {
          "$targetElement": "h2",
          "$name": "Subtitle"
        }
      },
      "3": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.3}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$targetElement": "h3",
          "$name": "Heading"
        }
      }
    },
    "body": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.3}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.2}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$targetElement": "p",
          "$name": "Body text"
        }
      }
    },
    "button": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.1}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.2}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$name": "Button"
        }
      }
    },
    "label": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.3}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.1}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$name": "Label"
        }
      }
    }
  }
}
