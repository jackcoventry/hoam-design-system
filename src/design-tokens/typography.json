{
  "typography": {
    "family": {
      "1": {
        "$type": "fontFamily",
        "$value": [
          "Dela Gothic One",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      },
      "2": {
        "$type": "fontFamily",
        "$value": [
          "Outfit",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      },
      "3": {
        "$type": "fontFamily",
        "$value": [
          "Outfit",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      }
    },
    "size": {
      "base": {
        "$type": "dimension",
        "$value": "18px"
      },
      "1": {
        "$type": "dimension",
        "$value": "14px"
      },
      "2": {
        "$type": "dimension",
        "$value": "{typography.size.base}"
      },
      "3": {
        "$type": "dimension",
        "$value": "24px"
      },
      "4": {
        "$type": "dimension",
        "$value": "32px"
      },
      "5": {
        "$type": "dimension",
        "$value": "40px"
      },
      "6": {
        "$type": "dimension",
        "$value": "110px"
      }
    },
    "line-height": {
      "1": {
        "$value": 1.5
      },
      "2": {
        "$value": 1.75
      },
      "3": {
        "$value": 1.25
      },
      "4": {
        "$value": 1.1
      }
    },
    "letter-spacing": {
      "1": {
        "$type": "dimension",
        "$value": "0"
      },
      "2": {
        "$type": "dimension",
        "$value": "1px"
      }
    },
    "weight": {
      "1": {
        "$type": "fontWeight",
        "$value": 400
      },
      "2": {
        "$type": "fontWeight",
        "$value": 700
      }
    },
    "title": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.2}",
          "fontSize": "{typography.size.6}",
          "lineHeight": "{typography.line-height.4}"
        },
        "$extensions": {
          "$targetElement": "h1",
          "$name": "Title 1"
        }
      },
      "2": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.5}",
          "lineHeight": "{typography.line-height.4}"
        },
        "$extensions": {
          "$targetElement": "h2"
        }
      },
      "3": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.3}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$targetElement": "h3"
        }
      },
      "4": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.2}",
          "fontSize": "{typography.size.2}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$targetElement": "h4"
        }
      },
      "5": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.2}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$targetElement": "h5"
        }
      }
    },
    "body": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.2}",
          "lineHeight": "{typography.line-height.1}"
        },
        "$extensions": {
          "$targetElement": "p"
        }
      }
    },
    "button": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.2}",
          "lineHeight": "{typography.line-height.1}"
        }
      }
    },
    "label": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.1}",
          "fontSize": "{typography.size.1}",
          "lineHeight": "{typography.line-height.1}"
        }
      },
      "2": {
        "$value": {
          "fontFamily": "{typography.family.2}",
          "fontWeight": "{typography.weight.2}",
          "fontSize": "{typography.size.1}",
          "lineHeight": "{typography.line-height.1}"
        }
      }
    }
  }
}
