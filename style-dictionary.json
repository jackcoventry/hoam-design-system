{
  "source": ["src/design-tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "src/styles/",
      "files": [
        {
          "destination": "variables.css",
          "format": "css/variables"
        }
      ],
      "prefix": "hoam",
      "options": {
        "usesDtcg": true
      }
    },
    "storybook": {
      "transformGroup": "css",
      "transforms": ["attribute/group", "attribute/set"],
      "buildPath": "src/styles/",
      "files": [
        {
          "destination": "variables.json",
          "format": "custom/json/flat-with-meta"
        }
      ],
      "options": {
        "usesDtcg": true
      }
    }
  }
}
