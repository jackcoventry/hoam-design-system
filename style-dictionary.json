{
  "source": ["src/design-tokens/**/*.json"],
  "platforms": {
    "scss": {
      "transformGroup": "css",
      "buildPath": "src/styles/",
      "files": [
        {
          "destination": "_variables.css",
          "format": "css/variables"
        }
      ],
      "prefix": "hoam",
      "options": {
        "usesDtcg": true
      }
    },
    "js": {
      "transformGroup": "js",
      "buildPath": "src/styles/",
      "files": [
        {
          "destination": "variables.json",
          "format": "json/nested"
        }
      ],
      "options": {
        "usesDtcg": true
      }
    },
    "cssClasses": {
      "transformGroup": "css",
      "buildPath": "src/styles/",
      "files": [
        {
          "destination": "classes.css",
          "format": "custom/css/classes"
        }
      ],
      "options": {
        "usesDtcg": true
      }
    }
  }
}
